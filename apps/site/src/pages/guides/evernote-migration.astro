---
import { getEntry, render } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";

const entry = await getEntry("blog", "evernote-migration-guide");

if (!entry) {
  throw new Error("Missing evernote-migration-guide blog entry");
}

const { Content } = await render(entry);
---

<BlogLayout
  frontmatter={entry.data}
  backHref="/"
  backLabel="返回首页"
  schemaType="Article"
>
  <Content />
</BlogLayout>
